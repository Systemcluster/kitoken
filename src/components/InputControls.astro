<style>
    button {
        padding: 0;
        margin: 0;
        border: none;
        background: none;
        color: var(--colors-text-primary);
    }
</style>
<>
    <button id="editor-copy" type="button"
        ><i class="ri-clipboard-line"></i></button
    >
    <button id="editor-stats" type="button"
        ><i class="ri-bar-chart-2-line"></i></button
    >
</>

<script>
    import { editorContent } from "@/stores";

    const check = (content: string) => {
        if (typeof content !== "string") return;
        if (!content) return;
        const stats = document.getElementById("stats");
    };
    check(editorContent.get());
    editorContent.subscribe((content) => check(content));
</script>
